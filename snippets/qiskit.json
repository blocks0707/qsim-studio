  "QFT": {
    "prefix": "qqft",
    "body": [
      "# Quantum Fourier Transform",
      "import numpy as np",
      "",
      "def qft(qc, n):",
      "    for i in range(n):",
      "        qc.h(i)",
      "        for j in range(i + 1, n):",
      "            qc.cp(np.pi / 2**(j - i), j, i)",
      "    # Swap qubits",
      "    for i in range(n // 2):",
      "        qc.swap(i, n - i - 1)",
      "",
      "qc = QuantumCircuit(${1:4})",
      "qft(qc, ${1:4})",
      ""
    ],
    "description": "Quantum Fourier Transform circuit"
  },
  "VQE Template": {
    "prefix": "qvqe",
    "body": [
      "# Variational Quantum Eigensolver (VQE)",
      "from qiskit import QuantumCircuit",
      "from qiskit_aer import AerSimulator",
      "import numpy as np",
      "",
      "def ansatz(params):",
      "    qc = QuantumCircuit(${1:2})",
      "    for i in range(${1:2}):",
      "        qc.ry(params[i], i)",
      "    for i in range(${1:2} - 1):",
      "        qc.cx(i, i + 1)",
      "    return qc",
      "",
      "# Define cost function and optimize",
      "params = np.random.uniform(0, 2 * np.pi, ${1:2})",
      "${0}"
    ],
    "description": "VQE variational ansatz template"
  },
  "Grover's Algorithm": {
    "prefix": "qgrover",
    "body": [
      "# Grover's Search Algorithm",
      "from qiskit import QuantumCircuit",
      "import numpy as np",
      "",
      "n = ${1:2}",
      "qc = QuantumCircuit(n, n)",
      "",
      "# Initialize superposition",
      "qc.h(range(n))",
      "",
      "# Oracle (mark target state |${2:11}⟩)",
      "qc.cz(0, 1)  # TODO: customize oracle",
      "",
      "# Diffusion operator",
      "qc.h(range(n))",
      "qc.x(range(n))",
      "qc.cz(0, 1)",
      "qc.x(range(n))",
      "qc.h(range(n))",
      "",
      "qc.measure(range(n), range(n))",
      "${0}"
    ],
    "description": "Grover's search algorithm basic structure"
  },
  "Quantum Teleportation": {
    "prefix": "qteleport",
    "body": [
      "# Quantum Teleportation Protocol",
      "from qiskit import QuantumCircuit",
      "",
      "qc = QuantumCircuit(3, 2)",
      "",
      "# Prepare state to teleport on qubit 0",
      "${1:qc.h(0)  # Example: teleport |+⟩}",
      "",
      "# Create Bell pair (qubits 1 & 2)",
      "qc.h(1)",
      "qc.cx(1, 2)",
      "",
      "# Bell measurement",
      "qc.cx(0, 1)",
      "qc.h(0)",
      "qc.measure(0, 0)",
      "qc.measure(1, 1)",
      "",
      "# Conditional corrections",
      "qc.x(2).c_if(1, 1)",
      "qc.z(2).c_if(0, 1)",
      "${0}"
    ],
    "description": "Quantum teleportation protocol"
  },
  "Error Correction (Bit-flip)": {
    "prefix": "qerror",
    "body": [
      "# Bit-flip Error Correction Code",
      "from qiskit import QuantumCircuit",
      "",
      "qc = QuantumCircuit(5, 2)  # 3 data + 2 ancilla",
      "",
      "# Encode: |ψ⟩ → |ψψψ⟩",
      "qc.cx(0, 1)",
      "qc.cx(0, 2)",
      "",
      "# Simulate error on qubit ${1:0}",
      "qc.x(${1:0})  # bit-flip error",
      "",
      "# Syndrome measurement",
      "qc.cx(0, 3)",
      "qc.cx(1, 3)",
      "qc.cx(1, 4)",
      "qc.cx(2, 4)",
      "qc.measure(3, 0)",
      "qc.measure(4, 1)",
      "",
      "# Correction based on syndrome",
      "${0}"
    ],
    "description": "3-qubit bit-flip error correction code"
  },
