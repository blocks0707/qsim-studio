  "Bell State": {
    "prefix": "qbell",
    "body": [
      "# Bell State (|00⟩ + |11⟩) / √2",
      "qc = QuantumCircuit(2, 2)",
      "qc.h(0)",
      "qc.cx(0, 1)",
      "qc.measure([0, 1], [0, 1])",
      ""
    ],
    "description": "Create a Bell state circuit"
  },
  "GHZ State": {
    "prefix": "qghz",
    "body": [
      "# GHZ State (|000⟩ + |111⟩) / √2",
      "n = ${1:3}",
      "qc = QuantumCircuit(n, n)",
      "qc.h(0)",
      "for i in range(1, n):",
      "    qc.cx(0, i)",
      "qc.measure_all()",
      ""
    ],
    "description": "Create a GHZ state circuit"
  },
