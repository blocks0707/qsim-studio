  "GHZ State": {
    "prefix": "qghz",
    "body": [
      "# GHZ State (|000⟩ + |111⟩) / √2",
      "n = ${1:3}",
      "qc = QuantumCircuit(n, n)",
      "qc.h(0)",
      "for i in range(1, n):",
      "    qc.cx(0, i)",
      "qc.measure_all()",
      ""
    ],
    "description": "Create a GHZ state circuit"
  },
